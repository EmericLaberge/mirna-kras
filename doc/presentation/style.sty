\setbeamercolor{block title warning}{fg=orange!60!yellow!90!black}

\newenvironment{warningblock}[1]{%
	\setbeamercolor{block title}{use=block title warning, fg=block title warning.fg}%

	\setbeamercolor{itemize item}{use=block title warning, fg=block title warning.fg}
	\setbeamertemplate{itemize item}{\small\faExclamationTriangle}

	\setbeamercolor{itemize subitem}{use=block title warning, fg=block title warning.fg}
	\setbeamertemplate{itemize item}{%
		\small%
		\ooalign{
			\hfil\raisebox{0pt}{\color{black}\rule{2pt}{6pt}}\hfil\cr
			\hfil\faExclamationTriangle\hfil\cr
		}%
	}

	\begin{block}{#1}%
		}{%
	\end{block}%
}

